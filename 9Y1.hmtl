<script>
(function() {

var IDS = ["q1","q2","q3","q4","q5","q6","q7","q8","q9","q10"];

var QTEXTS = [
  "Urkagina\u2019n\u0131n kanunlar\u0131 ba\u011flam\u0131nda S\u00fcmer hukukunun toplumsal d\u00fczen ve zay\u0131flar\u0131 koruma i\u015flevini a\u00e7\u0131klay\u0131n\u0131z.",
  "Hammurabi Kanunlar\u0131n\u0131 adalet ve s\u0131n\u0131fsal d\u00fczen a\u00e7\u0131s\u0131ndan de\u011flendirin\u0131z.",
  "Hitit hukuku ile Roma\u2019n\u0131n 12 Levha Kanunlar\u0131n\u0131 kar\u015f\u0131la\u015ft\u0131r\u0131n\u0131z.",
  "M\u0131s\u0131r\u2019da inan\u00e7 sisteminin mumyac\u0131l\u0131k, t\u0131p ve takvim bilimlerini nas\u0131l tetikledi\u011fini a\u00e7\u0131klay\u0131n\u0131z.",
  "S\u00fcmer zigguratlar\u0131n\u0131n dini ve bilimsel \u00e7ift i\u015flevini yorumlay\u0131n\u0131z.",
  "Antik Yunan\u2019da inan\u00e7tan ba\u011f\u0131ms\u0131zla\u015fma s\u00fcrecinin bilim ve felsefeye katk\u0131s\u0131n\u0131 de\u011flendirin\u0131z.",
  "Konar\u00f6\u00e7er ya\u015fam bi\u00e7iminin T\u00fcrk ordusu ve sava\u015f taktiklerini nas\u0131l bi\u00e7imlendirdi\u011fini a\u00e7\u0131klay\u0131n\u0131z.",
  "T\u00fcrk sanat\u0131nda Hayvan \u00dcslubunun ve ta\u015f\u0131nabilir nesnelerin \u00f6nemini konar\u00f6\u00e7erlikle ili\u015fkilendirin\u0131z.",
  "Kavimler G\u00f6\u00e7\u00fc\u2019n\u00fcn Bat\u0131 Roma\u2019n\u0131n \u00e7\u00f6k\u00fc\u015f\u00fc ve feodalizmin do\u011fu\u015fuyla olan nedensellik ili\u015fkisini a\u00e7\u0131klay\u0131n\u0131z.",
  "Kavimler G\u00f6\u00e7\u00fc\u2019n\u00fcn Avrupa medeniyetine olan yap\u0131c\u0131 k\u00fclt\u00fcrel katk\u0131lar\u0131n\u0131 tart\u0131\u015f\u0131n\u0131z."
];

var ANSWERS = [
  "Urkagina\u2019n\u0131n \u00e7\u0131kard\u0131\u011f\u0131 kanunlar, tarihte bilinen ilk yaz\u0131l\u0131 hukuk \u00f6rneklerinden biri olmas\u0131 bak\u0131m\u0131ndan b\u00fcy\u00fck \u00f6nem ta\u015f\u0131maktad\u0131r. Bu kanunlarla Urkagina; rahiplerin halk \u00fczerindeki s\u00f6m\u00fcr\u00fcs\u00fcn\u00fc k\u0131s\u0131tlam\u0131\u015f, h\u0131rs\u0131zl\u0131k ve \u015fiddet gibi toplumsal d\u00fczeni bozan eylemleri yasaklad\u0131. S\u00f6z konusu d\u00fczenlemeler \u00f6zellikle dul kad\u0131nlar\u0131 ve yetimleri koruma alt\u0131na ald\u0131\u011f\u0131ndan, hukukun ba\u015f\u0131ndan itibaren g\u00fc\u00e7l\u00fcler kar\u015f\u0131s\u0131nda zay\u0131flar\u0131 kollama i\u015flevi \u00fcstlendi\u011fi anla\u015f\u0131lmaktad\u0131r. Bu durum, hukukun yaln\u0131zca d\u00fczen de\u011fil, ayn\u0131 zamanda sosyal adalet arac\u0131 olarak da i\u015flev g\u00f6rd\u00fc\u011f\u00fcn\u00fc ortaya koymaktad\u0131r.",
  "Hammurabi Kanunlar\u0131, \u201ck\u0131sasa k\u0131sas\u201d ilkesiyle hem cayd\u0131r\u0131c\u0131l\u0131k hem de orant\u0131l\u0131 ceza anlay\u0131\u015f\u0131n\u0131 getirmi\u015ftir; bu y\u00f6n\u00fcyle adaleti temsil etti\u011fi s\u00f6ylenebilir. Ancak ayn\u0131 su\u00e7un cezas\u0131n\u0131n su\u00e7lunun toplumsal stat\u00fcs\u00fcne g\u00f6re farkl\u0131la\u015fmas\u0131, ger\u00e7ek anlamda bir e\u015fitlik sa\u011fland\u0131\u011f\u0131 izlenimini \u00e7\u00fcr\u00fctmektedir. Dolay\u0131s\u0131yla Hammurabi hukuku mevcut hiyerar\u015fik d\u00fczeni me\u015frula\u015ft\u0131ran bir sistem olarak de\u011ferlendirilebilir. Toplumsal d\u00fczen, korku ve a\u011f\u0131r cezalar arac\u0131l\u0131\u011f\u0131yla tesis edilmi\u015ftir; bu durum ise ger\u00e7ek adalet anlay\u0131\u015f\u0131ndan ziyade otoriter d\u00fczen anlay\u0131\u015f\u0131n\u0131 yans\u0131tmaktad\u0131r.",
  "Hitit hukuku, kasten ve kazara \u00f6ld\u00fcrmeyi birbirinden ay\u0131rarak nispi bir adalet anlay\u0131\u015f\u0131 geli\u015ftirmi\u015f; \u00f6l\u00fcm cezas\u0131 yerine maddi tazminat\u0131 esas alm\u0131\u015ft\u0131r. Kad\u0131nlara bo\u015fanma hakk\u0131 tan\u0131mas\u0131 ise toplumsal ilerlemenin somut bir g\u00f6stergesidir. Roma\u2019n\u0131n 12 Levha Kanunlar\u0131 ise farkl\u0131 bir ihtiyac\u0131n \u00fcr\u00fcn\u00fcyd\u00fc: Patriciler ile Plepler aras\u0131ndaki s\u0131n\u0131f \u00e7at\u0131\u015fmas\u0131n\u0131 durdurmak amac\u0131yla olu\u015fturulmu\u015ftur. Kanunlar\u0131n yaz\u0131l\u0131 levhalara i\u015flenmesi, hukukun keyfi yorumlanmas\u0131n\u0131 engellemi\u015f; m\u00fclkiyet, aile ve bor\u00e7lar alan\u0131n\u0131 kapsamas\u0131 hukuk g\u00fcvenli\u011finin temelini atm\u0131\u015ft\u0131r. Her iki sistem de toplumsal bar\u0131\u015f\u0131 sa\u011flam\u0131\u015f, ancak bunu farkl\u0131 y\u00f6ntemlerle ba\u015farm\u0131\u015ft\u0131r.",
  "M\u0131s\u0131r\u2019da firavunun \u201ctanr\u0131-kral\u201d stat\u00fcs\u00fc, \u00f6l\u00fcmden sonra dirilece\u011fine inan\u0131lan bu kutsal varl\u0131\u011f\u0131n bedeninin korunmas\u0131n\u0131 zorunlu k\u0131lm\u0131\u015ft\u0131r. Mumyac\u0131l\u0131k (tahnit) kapsam\u0131nda i\u00e7 organlar\u0131n \u00e7\u0131kar\u0131l\u0131p ila\u00e7lanmas\u0131, M\u0131s\u0131rl\u0131lar\u0131n insan anatomisini ayr\u0131nt\u0131l\u0131 bi\u00e7imde \u00f6\u011frenmesini sa\u011flam\u0131\u015f; bu bilgi birikimi t\u0131p ve eczac\u0131l\u0131k alan\u0131ndaki geli\u015fmeleri h\u0131zland\u0131rm\u0131\u015ft\u0131r. \u00d6te yandan Nil Nehri\u2019nin ta\u015fk\u0131nlar\u0131, tanr\u0131sal bir l\u00fctuf olarak yorumlanm\u0131\u015f; bu ta\u015fk\u0131nlar\u0131n zaman\u0131n\u0131 hesaplama zorunlulu\u011fu geometriyi ve G\u00fcne\u015f y\u0131l\u0131 esasl\u0131 takvimi do\u011furmu\u015ftur. K\u0131saca M\u0131s\u0131r\u2019da din, bilimin hem ilham kayna\u011f\u0131 hem de pratik g\u00fcds\u00fc olmu\u015ftur.",
  "S\u00fcmerlerde zigguratlar, tanr\u0131lar\u0131n yery\u00fczy\u00fcndeki konutu olarak in\u015fa edilmi\u015f \u00e7ok katl\u0131 tapmaklard\u0131r; bu nedenle ba\u015flang\u0131\u00e7ta dini i\u015flev ta\u015f\u0131maktad\u0131r. Ancak en \u00fcst kat\u0131n g\u00f6zlemevi olarak kullan\u0131lmas\u0131, dini ve bilimsel i\u015flevlerin i\u00e7 i\u00e7e ge\u00e7ti\u011fini g\u00f6stermektedir. S\u00fcmerli rahipler, tanr\u0131lar\u0131n g\u00f6ky\u00fcz\u00fcndeki iradelerini okumak amac\u0131yla Ay ile G\u00fcne\u015f tutulmalar\u0131n\u0131 ve gezegenlerin konumlar\u0131n\u0131 sistematik bi\u00e7imde g\u00f6zlemlediler. Bu dini ihtiya\u00e7, astronominin ve matemati\u011fin (Ay y\u0131l\u0131 takvimi, altm\u0131\u015fl\u0131k say\u0131 sistemi) temelini atm\u0131\u015ft\u0131r. Dolay\u0131s\u0131yla S\u00fcmer bilimi, inan\u00e7 pratiklerinin do\u011fal bir \u00fcr\u00fcn\u00fc olarak do\u011fmu\u015ftur.",
  "Antik Yunan\u2019da ba\u015flang\u0131\u00e7ta tanr\u0131lara adanan Olimpiyat oyunlar\u0131 ve Parthenon gibi tapinaklar, sanat ile mimarinin dini bir ama\u00e7 etraf\u0131nda \u015fekillendigini g\u00f6stermektedir. Ne var ki \u00f6zellikle \u0130yonya\u2019da do\u011fa filozoflar\u0131 do\u011fa olaylar\u0131n\u0131 tanr\u0131lar\u0131n gazab\u0131 yerine do\u011fal nedenlerle a\u00e7\u0131klamaya giri\u015fmi\u015ftir. Hipokrat da hastal\u0131\u011f\u0131n do\u011fa\u00fcst\u00fc de\u011fil, fizyolojik bir s\u00fcre\u00e7 oldu\u011funu savunarak modern t\u0131bb\u0131n \u00f6nc\u00fcs\u00fc say\u0131lm\u0131\u015ft\u0131r. Bu kopus, akl\u0131 esas alan felsefe ve pozitif bilimlerin inan\u00e7tan ba\u011f\u0131ms\u0131zla\u015fmas\u0131n\u0131n ba\u015flang\u0131c\u0131d\u0131r.",
  "Orta Asya\u2019n\u0131n geni\u015f bozkr\u0131lar\u0131 ve sert iklimi T\u00fcrklerin s\u00fcrekli hareket halinde ya\u015famas\u0131n\u0131 gerektirmi\u015f; bu durum onlar\u0131 do\u011fal olarak ata yatk\u0131n, dayan\u0131kl\u0131 ve \u00e7evik sava\u015f\u00e7\u0131lar haline getirmi\u015ftir. \u201cOrdu-millet\u201d anlay\u0131\u015f\u0131 \u00e7er\u00e7evesinde eli silah tutan her birey asker kabul edilmi\u015f, bu da geni\u015f bir seferber edilebilir kitleyi ortaya \u00e7\u0131karm\u0131\u015ft\u0131r. Mete Han, Asya Hun Devleti\u2019nde \u201cOnlu Sistem\u201d ad\u0131 verilen hiyerar\u015fik ordu te\u015fkilat\u0131n\u0131 kurarak disiplin ve koordinasyonu sa\u011flam\u0131\u015ft\u0131r. At \u00fczerinde geriye do\u011fru ok atma becerisi ve Turan (Hilal/Kurt Kapan\u0131) taktigi T\u00fcrklerin say\u0131ca \u00fcst\u00fcn d\u00fc\u015fman ordular\u0131n\u0131 da\u011f\u0131tabilmesini m\u00fcmk\u00fcn k\u0131lm\u0131\u015ft\u0131r.",
  "Konar\u00f6\u00e7er bir ya\u015fam bi\u00e7imi, kal\u0131c\u0131 mimari ya da a\u011f\u0131r e\u015fyalar \u00fcretmeyi olanaks\u0131z k\u0131lmaktad\u0131r; bu nedenle T\u00fcrk sanat\u0131, ta\u015f\u0131nmas\u0131 kolay g\u00fcndelik nesneler \u00fczerinde geli\u015fmi\u015ftir. Do\u011fayla i\u00e7 i\u00e7e ge\u00e7en bozkr\u0131r ya\u015fant\u0131s\u0131, sanat\u00e7\u0131lar\u0131n bak\u0131\u015flar\u0131n\u0131 hayvanlar d\u00fcnyas\u0131na y\u00f6neltmi\u015ftir; av sahneleri, m\u00fccadele eden hayvanlar (kurt, kaplan, geyik) ve g\u00fc\u00e7 simgeleri bu sanat\u0131n ana temalar\u0131n\u0131 olu\u015fturmaktad\u0131r. \u201cHayvan \u00dcslubunu\u201d olarak adland\u0131r\u0131lan bu estetik anlay\u0131\u015f, hem T\u00fcrklerin do\u011fayla kurduklar\u0131 derin ili\u015fkiyi hem de ta\u015f\u0131nabilir g\u00fczelli\u011fe verdikleri \u00f6nemi yans\u0131tmaktad\u0131r.",
  "Hunlar\u0131n Do\u011fu Avrupa\u2019ya dalmas\u0131, b\u00f6lgedeki Germen kavimlerini Roma s\u0131n\u0131rlar\u0131na do\u011fru itmi\u015f; Roma \u0130mparatorlu\u011fu bu bask\u0131ya dayanamayarak 395\u2019te ikiye ayr\u0131lm\u0131\u015f ve Bat\u0131 Roma 476\u2019da tarihe kar\u0131\u015fm\u0131\u015ft\u0131r. Merkezi otoritenin \u00e7\u00f6k\u00fc\u015f\u00fcyle birlikte Avrupa\u2019da b\u00fcy\u00fck bir g\u00fc\u00e7 bo\u015flu\u011fu do\u011fmu\u015f; bu bo\u015flu\u011fu yerel toprak sahipleri (kontlar, d\u00fckler) doldurmaya ba\u015flam\u0131\u015ft\u0131r. Toprak kar\u015f\u0131l\u0131\u011f\u0131 askerlik hizmetine dayanan feodalizm sistemi bu s\u00fcre\u00e7te ortaya \u00e7\u0131km\u0131\u015ft\u0131r. Karga\u015fa ortam\u0131 ise halk\u0131 s\u0131\u011f\u0131nak olarak Kilise\u2019ye y\u00f6neltmi\u015f, Papal\u0131\u011f\u0131n siyasi ve ruhani n\u00fcfuzunu h\u0131zla art\u0131rm\u0131\u015f ve Skolastik d\u00fc\u015f\u00fcncenin Avrupa\u2019da egemen olmas\u0131na zemin haz\u0131rlam\u0131\u015ft\u0131r.",
  "Kavimler G\u00f6\u00e7\u00fc\u2019ne ili\u015fkin tek tarafl\u0131 bir \u201cbarbar istila\u015f\u0131\u201d anlat\u0131s\u0131 ger\u00e7e\u011fin yaln\u0131zca bir boyutunu yans\u0131tmaktad\u0131r. T\u00fcrk-Hun k\u00f6kenli g\u00f6\u00e7ebeler ile Roma s\u0131n\u0131rlar\u0131ndaki topluluklar aras\u0131nda yo\u011fun bir k\u00fclt\u00fcrel al\u0131\u015fveri\u015f ya\u015fanm\u0131\u015ft\u0131r. Hunlar\u0131n getirdi\u011fi pantolon ve ceket giysisi, Avrupal\u0131 iklim ko\u015fullar\u0131nda pratik bir \u00e7\u00f6z\u00fcm olarak benimsendi. \u00dczengi, s\u00fcvari sava\u015f\u0131n\u0131n seyrine y\u00f6n verdi ve Avrupal\u0131 \u015f\u00f6valyelik gelene\u011finin teknik temelini olu\u015fturdu. Atl\u0131 s\u00fcvari taktikleri ise a\u011f\u0131r piyadeye dayanan Avrupa ordular\u0131n\u0131 d\u00f6n\u00fc\u015ft\u00fcrd\u00fc. K\u0131saca Kavimler G\u00f6\u00e7\u00fc, Avrupa\u2019y\u0131 hem yeniden \u015fekillendiren bir y\u0131k\u0131m hem de onu teknolojik ve k\u00fclt\u00fcrel a\u00e7\u0131dan zenginle\u015ftiren bir sentez s\u00fcrecidir."
];

var KZTAGS = [
  {label:"Kazan\u0131m 1",code:"TAR.9.2.3",cls:"kn1"},
  {label:"Kazan\u0131m 1",code:"TAR.9.2.3",cls:"kn1"},
  {label:"Kazan\u0131m 1",code:"TAR.9.2.3",cls:"kn1"},
  {label:"Kazan\u0131m 2",code:"TAR.9.2.4",cls:"kn2"},
  {label:"Kazan\u0131m 2",code:"TAR.9.2.4",cls:"kn2"},
  {label:"Kazan\u0131m 2",code:"TAR.9.2.4",cls:"kn2"},
  {label:"Kazan\u0131m 3",code:"TAR.9.2.5",cls:"kn3"},
  {label:"Kazan\u0131m 3",code:"TAR.9.2.5",cls:"kn3"},
  {label:"Kazan\u0131m 4",code:"TAR.9.3.1",cls:"kn4"},
  {label:"Kazan\u0131m 4",code:"TAR.9.3.1",cls:"kn4"}
];

function updateProg() {
  var filled = 0;
  for (var i = 0; i < IDS.length; i++) {
    if (document.getElementById(IDS[i]).value.trim().length > 0) filled++;
  }
  document.getElementById("pgBar").style.width = (filled * 10) + "%";
  document.getElementById("pgCnt").textContent = filled + " / 10";
}

function esc(s) {
  return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
}

function showResults() {
  var container = document.getElementById("res-container");
  container.innerHTML = "";
  for (var i = 0; i < IDS.length; i++) {
    var val = document.getElementById(IDS[i]).value.trim();
    var kz = KZTAGS[i];
    var card = document.createElement("div");
    card.className = "rcard";
    card.innerHTML =
      "<div class='rcard-top'>" +
        "<span class='rnum'>" + (i+1) + ".</span>" +
        "<span class='rkaz-tag " + kz.cls + "'>" + kz.label + " \u00b7 " + kz.code + "</span>" +
        "<span class='rqtext'>" + QTEXTS[i] + "</span>" +
      "</div>" +
      "<div class='rcard-body'>" +
        "<div class='answer-section'>" +
          "<div class='ans-label ans-label-s'>Sizin Cevab\u0131n\u0131z</div>" +
          "<div class='ans-text" + (val ? "" : " empty") + "'>" + (val ? esc(val) : "Bu soru yan\u0131ts\u0131z b\u0131rak\u0131lm\u0131\u015ft\u0131r.") + "</div>" +
        "</div>" +
        "<div class='answer-section'>" +
          "<div class='ans-label ans-label-a'>\u00d6rnek Do\u011fru Yan\u0131t</div>" +
          "<div class='ans-text model'>" + ANSWERS[i] + "</div>" +
        "</div>" +
      "</div>";
    container.appendChild(card);
  }
  document.getElementById("exam-page").style.display = "none";
  document.getElementById("results-page").style.display = "block";
  window.scrollTo(0, 0);
}

function goBack() {
  document.getElementById("results-page").style.display = "none";
  document.getElementById("exam-page").style.display = "block";
  window.scrollTo(0, 0);
}

document.getElementById("btnFinish").onclick = showResults;
document.getElementById("btnBack").onclick = goBack;

})();
</script>

</div>

<script id="sinav-script">

(function() {

var IDS = ["q1","q2","q3","q4","q5","q6","q7","q8","q9","q10"];

var QTEXTS = [
  "Urkagina\u2019n\u0131n kanunlar\u0131 ba\u011flam\u0131nda S\u00fcmer hukukunun toplumsal d\u00fczen ve zay\u0131flar\u0131 koruma i\u015flevini a\u00e7\u0131klay\u0131n\u0131z.",
  "Hammurabi Kanunlar\u0131n\u0131 adalet ve s\u0131n\u0131fsal d\u00fczen a\u00e7\u0131s\u0131ndan de\u011flendirin\u0131z.",
  "Hitit hukuku ile Roma\u2019n\u0131n 12 Levha Kanunlar\u0131n\u0131 kar\u015f\u0131la\u015ft\u0131r\u0131n\u0131z.",
  "M\u0131s\u0131r\u2019da inan\u00e7 sisteminin mumyac\u0131l\u0131k, t\u0131p ve takvim bilimlerini nas\u0131l tetikledi\u011fini a\u00e7\u0131klay\u0131n\u0131z.",
  "S\u00fcmer zigguratlar\u0131n\u0131n dini ve bilimsel \u00e7ift i\u015flevini yorumlay\u0131n\u0131z.",
  "Antik Yunan\u2019da inan\u00e7tan ba\u011f\u0131ms\u0131zla\u015fma s\u00fcrecinin bilim ve felsefeye katk\u0131s\u0131n\u0131 de\u011flendirin\u0131z.",
  "Konar\u00f6\u00e7er ya\u015fam bi\u00e7iminin T\u00fcrk ordusu ve sava\u015f taktiklerini nas\u0131l bi\u00e7imlendirdi\u011fini a\u00e7\u0131klay\u0131n\u0131z.",
  "T\u00fcrk sanat\u0131nda Hayvan \u00dcslubunun ve ta\u015f\u0131nabilir nesnelerin \u00f6nemini konar\u00f6\u00e7erlikle ili\u015fkilendirin\u0131z.",
  "Kavimler G\u00f6\u00e7\u00fc\u2019n\u00fcn Bat\u0131 Roma\u2019n\u0131n \u00e7\u00f6k\u00fc\u015f\u00fc ve feodalizmin do\u011fu\u015fuyla olan nedensellik ili\u015fkisini a\u00e7\u0131klay\u0131n\u0131z.",
  "Kavimler G\u00f6\u00e7\u00fc\u2019n\u00fcn Avrupa medeniyetine olan yap\u0131c\u0131 k\u00fclt\u00fcrel katk\u0131lar\u0131n\u0131 tart\u0131\u015f\u0131n\u0131z."
];

var ANSWERS = [
  "Urkagina\u2019n\u0131n \u00e7\u0131kard\u0131\u011f\u0131 kanunlar, tarihte bilinen ilk yaz\u0131l\u0131 hukuk \u00f6rneklerinden biri olmas\u0131 bak\u0131m\u0131ndan b\u00fcy\u00fck \u00f6nem ta\u015f\u0131maktad\u0131r. Bu kanunlarla Urkagina; rahiplerin halk \u00fczerindeki s\u00f6m\u00fcr\u00fcs\u00fcn\u00fc k\u0131s\u0131tlam\u0131\u015f, h\u0131rs\u0131zl\u0131k ve \u015fiddet gibi toplumsal d\u00fczeni bozan eylemleri yasaklad\u0131. S\u00f6z konusu d\u00fczenlemeler \u00f6zellikle dul kad\u0131nlar\u0131 ve yetimleri koruma alt\u0131na ald\u0131\u011f\u0131ndan, hukukun ba\u015f\u0131ndan itibaren g\u00fc\u00e7l\u00fcler kar\u015f\u0131s\u0131nda zay\u0131flar\u0131 kollama i\u015flevi \u00fcstlendi\u011fi anla\u015f\u0131lmaktad\u0131r. Bu durum, hukukun yaln\u0131zca d\u00fczen de\u011fil, ayn\u0131 zamanda sosyal adalet arac\u0131 olarak da i\u015flev g\u00f6rd\u00fc\u011f\u00fcn\u00fc ortaya koymaktad\u0131r.",
  "Hammurabi Kanunlar\u0131, \u201ck\u0131sasa k\u0131sas\u201d ilkesiyle hem cayd\u0131r\u0131c\u0131l\u0131k hem de orant\u0131l\u0131 ceza anlay\u0131\u015f\u0131n\u0131 getirmi\u015ftir; bu y\u00f6n\u00fcyle adaleti temsil etti\u011fi s\u00f6ylenebilir. Ancak ayn\u0131 su\u00e7un cezas\u0131n\u0131n su\u00e7lunun toplumsal stat\u00fcs\u00fcne g\u00f6re farkl\u0131la\u015fmas\u0131, ger\u00e7ek anlamda bir e\u015fitlik sa\u011fland\u0131\u011f\u0131 izlenimini \u00e7\u00fcr\u00fctmektedir. Dolay\u0131s\u0131yla Hammurabi hukuku mevcut hiyerar\u015fik d\u00fczeni me\u015frula\u015ft\u0131ran bir sistem olarak de\u011ferlendirilebilir. Toplumsal d\u00fczen, korku ve a\u011f\u0131r cezalar arac\u0131l\u0131\u011f\u0131yla tesis edilmi\u015ftir; bu durum ise ger\u00e7ek adalet anlay\u0131\u015f\u0131ndan ziyade otoriter d\u00fczen anlay\u0131\u015f\u0131n\u0131 yans\u0131tmaktad\u0131r.",
  "Hitit hukuku, kasten ve kazara \u00f6ld\u00fcrmeyi birbirinden ay\u0131rarak nispi bir adalet anlay\u0131\u015f\u0131 geli\u015ftirmi\u015f; \u00f6l\u00fcm cezas\u0131 yerine maddi tazminat\u0131 esas alm\u0131\u015ft\u0131r. Kad\u0131nlara bo\u015fanma hakk\u0131 tan\u0131mas\u0131 ise toplumsal ilerlemenin somut bir g\u00f6stergesidir. Roma\u2019n\u0131n 12 Levha Kanunlar\u0131 ise farkl\u0131 bir ihtiyac\u0131n \u00fcr\u00fcn\u00fcyd\u00fc: Patriciler ile Plepler aras\u0131ndaki s\u0131n\u0131f \u00e7at\u0131\u015fmas\u0131n\u0131 durdurmak amac\u0131yla olu\u015fturulmu\u015ftur. Kanunlar\u0131n yaz\u0131l\u0131 levhalara i\u015flenmesi, hukukun keyfi yorumlanmas\u0131n\u0131 engellemi\u015f; m\u00fclkiyet, aile ve bor\u00e7lar alan\u0131n\u0131 kapsamas\u0131 hukuk g\u00fcvenli\u011finin temelini atm\u0131\u015ft\u0131r. Her iki sistem de toplumsal bar\u0131\u015f\u0131 sa\u011flam\u0131\u015f, ancak bunu farkl\u0131 y\u00f6ntemlerle ba\u015farm\u0131\u015ft\u0131r.",
  "M\u0131s\u0131r\u2019da firavunun \u201ctanr\u0131-kral\u201d stat\u00fcs\u00fc, \u00f6l\u00fcmden sonra dirilece\u011fine inan\u0131lan bu kutsal varl\u0131\u011f\u0131n bedeninin korunmas\u0131n\u0131 zorunlu k\u0131lm\u0131\u015ft\u0131r. Mumyac\u0131l\u0131k (tahnit) kapsam\u0131nda i\u00e7 organlar\u0131n \u00e7\u0131kar\u0131l\u0131p ila\u00e7lanmas\u0131, M\u0131s\u0131rl\u0131lar\u0131n insan anatomisini ayr\u0131nt\u0131l\u0131 bi\u00e7imde \u00f6\u011frenmesini sa\u011flam\u0131\u015f; bu bilgi birikimi t\u0131p ve eczac\u0131l\u0131k alan\u0131ndaki geli\u015fmeleri h\u0131zland\u0131rm\u0131\u015ft\u0131r. \u00d6te yandan Nil Nehri\u2019nin ta\u015fk\u0131nlar\u0131, tanr\u0131sal bir l\u00fctuf olarak yorumlanm\u0131\u015f; bu ta\u015fk\u0131nlar\u0131n zaman\u0131n\u0131 hesaplama zorunlulu\u011fu geometriyi ve G\u00fcne\u015f y\u0131l\u0131 esasl\u0131 takvimi do\u011furmu\u015ftur. K\u0131saca M\u0131s\u0131r\u2019da din, bilimin hem ilham kayna\u011f\u0131 hem de pratik g\u00fcds\u00fc olmu\u015ftur.",
  "S\u00fcmerlerde zigguratlar, tanr\u0131lar\u0131n yery\u00fczy\u00fcndeki konutu olarak in\u015fa edilmi\u015f \u00e7ok katl\u0131 tapmaklard\u0131r; bu nedenle ba\u015flang\u0131\u00e7ta dini i\u015flev ta\u015f\u0131maktad\u0131r. Ancak en \u00fcst kat\u0131n g\u00f6zlemevi olarak kullan\u0131lmas\u0131, dini ve bilimsel i\u015flevlerin i\u00e7 i\u00e7e ge\u00e7ti\u011fini g\u00f6stermektedir. S\u00fcmerli rahipler, tanr\u0131lar\u0131n g\u00f6ky\u00fcz\u00fcndeki iradelerini okumak amac\u0131yla Ay ile G\u00fcne\u015f tutulmalar\u0131n\u0131 ve gezegenlerin konumlar\u0131n\u0131 sistematik bi\u00e7imde g\u00f6zlemlediler. Bu dini ihtiya\u00e7, astronominin ve matemati\u011fin (Ay y\u0131l\u0131 takvimi, altm\u0131\u015fl\u0131k say\u0131 sistemi) temelini atm\u0131\u015ft\u0131r. Dolay\u0131s\u0131yla S\u00fcmer bilimi, inan\u00e7 pratiklerinin do\u011fal bir \u00fcr\u00fcn\u00fc olarak do\u011fmu\u015ftur.",
  "Antik Yunan\u2019da ba\u015flang\u0131\u00e7ta tanr\u0131lara adanan Olimpiyat oyunlar\u0131 ve Parthenon gibi tapinaklar, sanat ile mimarinin dini bir ama\u00e7 etraf\u0131nda \u015fekillendigini g\u00f6stermektedir. Ne var ki \u00f6zellikle \u0130yonya\u2019da do\u011fa filozoflar\u0131 do\u011fa olaylar\u0131n\u0131 tanr\u0131lar\u0131n gazab\u0131 yerine do\u011fal nedenlerle a\u00e7\u0131klamaya giri\u015fmi\u015ftir. Hipokrat da hastal\u0131\u011f\u0131n do\u011fa\u00fcst\u00fc de\u011fil, fizyolojik bir s\u00fcre\u00e7 oldu\u011funu savunarak modern t\u0131bb\u0131n \u00f6nc\u00fcs\u00fc say\u0131lm\u0131\u015ft\u0131r. Bu kopus, akl\u0131 esas alan felsefe ve pozitif bilimlerin inan\u00e7tan ba\u011f\u0131ms\u0131zla\u015fmas\u0131n\u0131n ba\u015flang\u0131c\u0131d\u0131r.",
  "Orta Asya\u2019n\u0131n geni\u015f bozkr\u0131lar\u0131 ve sert iklimi T\u00fcrklerin s\u00fcrekli hareket halinde ya\u015famas\u0131n\u0131 gerektirmi\u015f; bu durum onlar\u0131 do\u011fal olarak ata yatk\u0131n, dayan\u0131kl\u0131 ve \u00e7evik sava\u015f\u00e7\u0131lar haline getirmi\u015ftir. \u201cOrdu-millet\u201d anlay\u0131\u015f\u0131 \u00e7er\u00e7evesinde eli silah tutan her birey asker kabul edilmi\u015f, bu da geni\u015f bir seferber edilebilir kitleyi ortaya \u00e7\u0131karm\u0131\u015ft\u0131r. Mete Han, Asya Hun Devleti\u2019nde \u201cOnlu Sistem\u201d ad\u0131 verilen hiyerar\u015fik ordu te\u015fkilat\u0131n\u0131 kurarak disiplin ve koordinasyonu sa\u011flam\u0131\u015ft\u0131r. At \u00fczerinde geriye do\u011fru ok atma becerisi ve Turan (Hilal/Kurt Kapan\u0131) taktigi T\u00fcrklerin say\u0131ca \u00fcst\u00fcn d\u00fc\u015fman ordular\u0131n\u0131 da\u011f\u0131tabilmesini m\u00fcmk\u00fcn k\u0131lm\u0131\u015ft\u0131r.",
  "Konar\u00f6\u00e7er bir ya\u015fam bi\u00e7imi, kal\u0131c\u0131 mimari ya da a\u011f\u0131r e\u015fyalar \u00fcretmeyi olanaks\u0131z k\u0131lmaktad\u0131r; bu nedenle T\u00fcrk sanat\u0131, ta\u015f\u0131nmas\u0131 kolay g\u00fcndelik nesneler \u00fczerinde geli\u015fmi\u015ftir. Do\u011fayla i\u00e7 i\u00e7e ge\u00e7en bozkr\u0131r ya\u015fant\u0131s\u0131, sanat\u00e7\u0131lar\u0131n bak\u0131\u015flar\u0131n\u0131 hayvanlar d\u00fcnyas\u0131na y\u00f6neltmi\u015ftir; av sahneleri, m\u00fccadele eden hayvanlar (kurt, kaplan, geyik) ve g\u00fc\u00e7 simgeleri bu sanat\u0131n ana temalar\u0131n\u0131 olu\u015fturmaktad\u0131r. \u201cHayvan \u00dcslubunu\u201d olarak adland\u0131r\u0131lan bu estetik anlay\u0131\u015f, hem T\u00fcrklerin do\u011fayla kurduklar\u0131 derin ili\u015fkiyi hem de ta\u015f\u0131nabilir g\u00fczelli\u011fe verdikleri \u00f6nemi yans\u0131tmaktad\u0131r.",
  "Hunlar\u0131n Do\u011fu Avrupa\u2019ya dalmas\u0131, b\u00f6lgedeki Germen kavimlerini Roma s\u0131n\u0131rlar\u0131na do\u011fru itmi\u015f; Roma \u0130mparatorlu\u011fu bu bask\u0131ya dayanamayarak 395\u2019te ikiye ayr\u0131lm\u0131\u015f ve Bat\u0131 Roma 476\u2019da tarihe kar\u0131\u015fm\u0131\u015ft\u0131r. Merkezi otoritenin \u00e7\u00f6k\u00fc\u015f\u00fcyle birlikte Avrupa\u2019da b\u00fcy\u00fck bir g\u00fc\u00e7 bo\u015flu\u011fu do\u011fmu\u015f; bu bo\u015flu\u011fu yerel toprak sahipleri (kontlar, d\u00fckler) doldurmaya ba\u015flam\u0131\u015ft\u0131r. Toprak kar\u015f\u0131l\u0131\u011f\u0131 askerlik hizmetine dayanan feodalizm sistemi bu s\u00fcre\u00e7te ortaya \u00e7\u0131km\u0131\u015ft\u0131r. Karga\u015fa ortam\u0131 ise halk\u0131 s\u0131\u011f\u0131nak olarak Kilise\u2019ye y\u00f6neltmi\u015f, Papal\u0131\u011f\u0131n siyasi ve ruhani n\u00fcfuzunu h\u0131zla art\u0131rm\u0131\u015f ve Skolastik d\u00fc\u015f\u00fcncenin Avrupa\u2019da egemen olmas\u0131na zemin haz\u0131rlam\u0131\u015ft\u0131r.",
  "Kavimler G\u00f6\u00e7\u00fc\u2019ne ili\u015fkin tek tarafl\u0131 bir \u201cbarbar istila\u015f\u0131\u201d anlat\u0131s\u0131 ger\u00e7e\u011fin yaln\u0131zca bir boyutunu yans\u0131tmaktad\u0131r. T\u00fcrk-Hun k\u00f6kenli g\u00f6\u00e7ebeler ile Roma s\u0131n\u0131rlar\u0131ndaki topluluklar aras\u0131nda yo\u011fun bir k\u00fclt\u00fcrel al\u0131\u015fveri\u015f ya\u015fanm\u0131\u015ft\u0131r. Hunlar\u0131n getirdi\u011fi pantolon ve ceket giysisi, Avrupal\u0131 iklim ko\u015fullar\u0131nda pratik bir \u00e7\u00f6z\u00fcm olarak benimsendi. \u00dczengi, s\u00fcvari sava\u015f\u0131n\u0131n seyrine y\u00f6n verdi ve Avrupal\u0131 \u015f\u00f6valyelik gelene\u011finin teknik temelini olu\u015fturdu. Atl\u0131 s\u00fcvari taktikleri ise a\u011f\u0131r piyadeye dayanan Avrupa ordular\u0131n\u0131 d\u00f6n\u00fc\u015ft\u00fcrd\u00fc. K\u0131saca Kavimler G\u00f6\u00e7\u00fc, Avrupa\u2019y\u0131 hem yeniden \u015fekillendiren bir y\u0131k\u0131m hem de onu teknolojik ve k\u00fclt\u00fcrel a\u00e7\u0131dan zenginle\u015ftiren bir sentez s\u00fcrecidir."
];

var KZTAGS = [
  {label:"Kazan\u0131m 1",code:"TAR.9.2.3",cls:"kn1"},
  {label:"Kazan\u0131m 1",code:"TAR.9.2.3",cls:"kn1"},
  {label:"Kazan\u0131m 1",code:"TAR.9.2.3",cls:"kn1"},
  {label:"Kazan\u0131m 2",code:"TAR.9.2.4",cls:"kn2"},
  {label:"Kazan\u0131m 2",code:"TAR.9.2.4",cls:"kn2"},
  {label:"Kazan\u0131m 2",code:"TAR.9.2.4",cls:"kn2"},
  {label:"Kazan\u0131m 3",code:"TAR.9.2.5",cls:"kn3"},
  {label:"Kazan\u0131m 3",code:"TAR.9.2.5",cls:"kn3"},
  {label:"Kazan\u0131m 4",code:"TAR.9.3.1",cls:"kn4"},
  {label:"Kazan\u0131m 4",code:"TAR.9.3.1",cls:"kn4"}
];

function updateProg() {
  var filled = 0;
  for (var i = 0; i < IDS.length; i++) {
    if (document.getElementById(IDS[i]).value.trim().length > 0) filled++;
  }
  document.getElementById("pgBar").style.width = (filled * 10) + "%";
  document.getElementById("pgCnt").textContent = filled + " / 10";
}

function esc(s) {
  return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
}

function showResults() {
  var container = document.getElementById("res-container");
  container.innerHTML = "";
  for (var i = 0; i < IDS.length; i++) {
    var val = document.getElementById(IDS[i]).value.trim();
    var kz = KZTAGS[i];
    var card = document.createElement("div");
    card.className = "rcard";
    card.innerHTML =
      "<div class='rcard-top'>" +
        "<span class='rnum'>" + (i+1) + ".</span>" +
        "<span class='rkaz-tag " + kz.cls + "'>" + kz.label + " \u00b7 " + kz.code + "</span>" +
        "<span class='rqtext'>" + QTEXTS[i] + "</span>" +
      "</div>" +
      "<div class='rcard-body'>" +
        "<div class='answer-section'>" +
          "<div class='ans-label ans-label-s'>Sizin Cevab\u0131n\u0131z</div>" +
          "<div class='ans-text" + (val ? "" : " empty") + "'>" + (val ? esc(val) : "Bu soru yan\u0131ts\u0131z b\u0131rak\u0131lm\u0131\u015ft\u0131r.") + "</div>" +
        "</div>" +
        "<div class='answer-section'>" +
          "<div class='ans-label ans-label-a'>\u00d6rnek Do\u011fru Yan\u0131t</div>" +
          "<div class='ans-text model'>" + ANSWERS[i] + "</div>" +
        "</div>" +
      "</div>";
    container.appendChild(card);
  }
  document.getElementById("exam-page").style.display = "none";
  document.getElementById("sinav-results-page").style.display = "block";
  window.scrollTo(0, 0);
}

function goBack() {
  document.getElementById("sinav-results-page").style.display = "none";
  document.getElementById("exam-page").style.display = "block";
  window.scrollTo(0, 0);
}

document.getElementById("btnFinish").onclick = showResults;
document.getElementById("btnBack").onclick = goBack;

})();

</script>

<script id="sinav-glue">
(function() {
  var overlay = document.getElementById('sinav-overlay');
  document.getElementById('btnOrnekSinav').onclick = function() {
    overlay.classList.add('active');
    overlay.scrollTop = 0;
  };
  document.getElementById('btnDerseDon').onclick = function() {
    overlay.classList.remove('active');
  };
})();
</script>

<!-- ══ YATAY KAYDIRMA İPUCU SİSTEMİ ══ -->
<style id="scroll-hint-styles">

/* ── SARMALAYICI ── */
.scroll-hint-wrap {
  position: relative;
  display: block;
}

/* ── SOL / SAĞ FADE KENAR ── */
.scroll-hint-wrap::before,
.scroll-hint-wrap::after {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  width: 48px;
  pointer-events: none;
  z-index: 5;
  transition: opacity .35s ease;
}
.scroll-hint-wrap::before {
  left: 0;
  background: linear-gradient(to right, rgba(250,246,237,0.95), transparent);
  opacity: 0; /* başta sol kenar gizli — içerik en solda */
}
.scroll-hint-wrap::after {
  right: 0;
  background: linear-gradient(to left, rgba(250,246,237,0.95), transparent);
}
.scroll-hint-wrap.at-start::before  { opacity: 0; }
.scroll-hint-wrap.at-end::after     { opacity: 0; }
.scroll-hint-wrap.can-left::before  { opacity: 1; }
.scroll-hint-wrap.can-right::after  { opacity: 1; }

/* ── OK İPUCU BANDI ── */
.scroll-hint-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 5px 14px;
  background: rgba(29,61,107,0.07);
  border: 1px solid rgba(29,61,107,0.12);
  border-top: none;
  border-radius: 0 0 4px 4px;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--steel, #4a6fa5);
  user-select: none;
  overflow: hidden;
  transition: max-height .4s ease, opacity .4s ease, padding .4s ease;
  max-height: 36px;
  opacity: 1;
}
.scroll-hint-bar.hidden {
  max-height: 0;
  opacity: 0;
  padding-top: 0;
  padding-bottom: 0;
}
.scroll-hint-bar .sh-arrow {
  display: inline-block;
  animation: sh-bounce 1.2s ease-in-out infinite;
  font-size: 13px;
  line-height: 1;
}
.scroll-hint-bar .sh-arrow.left  { animation-delay: 0s; }
.scroll-hint-bar .sh-arrow.right { animation-delay: .15s; }

@keyframes sh-bounce {
  0%, 100% { transform: translateX(0); opacity: .5; }
  50%       { transform: translateX(4px); opacity: 1; }
}
.scroll-hint-bar .sh-arrow.left {
  animation-name: sh-bounce-left;
}
@keyframes sh-bounce-left {
  0%, 100% { transform: translateX(0); opacity: .5; }
  50%       { transform: translateX(-4px); opacity: 1; }
}

/* ── NAV TABS İPUCU ── */
.nav-scroll-hint {
  display: none;
  align-items: center;
  justify-content: flex-end;
  gap: 5px;
  padding: 3px 16px 3px 0;
  background: var(--parchment, #f5f0e8);
  border-bottom: 1px solid rgba(29,61,107,0.1);
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9.5px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--steel, #4a6fa5);
  position: relative;
  z-index: 10;
  animation: sh-fade-in .5s ease .8s both;
}
.nav-scroll-hint.visible { display: flex; }
.nav-scroll-hint .sh-dot {
  width: 5px; height: 5px;
  background: var(--red, #8b2020);
  border-radius: 50%;
  animation: sh-dot-pulse 1.4s ease-in-out infinite;
}
@keyframes sh-dot-pulse {
  0%,100% { transform: scale(1); opacity: .6; }
  50%     { transform: scale(1.5); opacity: 1; }
}
@keyframes sh-fade-in {
  from { opacity: 0; transform: translateY(-4px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Nav tabs sağ fade */
.nav-tabs-wrap {
  position: relative;
}
.nav-tabs-wrap::after {
  content: '';
  position: absolute;
  top: 0; right: 0; bottom: 0;
  width: 56px;
  background: linear-gradient(to left, var(--parchment, #f5f0e8), transparent);
  pointer-events: none;
  z-index: 5;
  transition: opacity .3s;
}
.nav-tabs-wrap.at-end::after { opacity: 0; }

</style>

<script id="scroll-hint-script">
(function () {
  "use strict";

  /* ── Yardımcılar ── */
  function canScrollH(el) {
    return el.scrollWidth > el.clientWidth + 2;
  }

  /* ── TABLOLAR ── */
  function initTableHints() {
    var tables = document.querySelectorAll(".comp-table");
    tables.forEach(function (tbl) {
      /* Sarmalayıcı div oluştur */
      var wrap = document.createElement("div");
      wrap.className = "scroll-hint-wrap can-right at-start";
      tbl.parentNode.insertBefore(wrap, tbl);
      wrap.appendChild(tbl);

      /* İpucu bandı */
      var bar = document.createElement("div");
      bar.className = "scroll-hint-bar";
      bar.innerHTML =
        '<span class="sh-arrow left">&#8592;</span>' +
        '<span>kayd&#305;r</span>' +
        '<span class="sh-arrow right">&#8594;</span>';
      wrap.parentNode.insertBefore(bar, wrap.nextSibling);

      /* Scroll olayı */
      function update() {
        var atStart = tbl.scrollLeft <= 2;
        var atEnd   = tbl.scrollLeft >= tbl.scrollWidth - tbl.clientWidth - 2;
        wrap.classList.toggle("at-start",  atStart);
        wrap.classList.toggle("at-end",    atEnd);
        wrap.classList.toggle("can-left",  !atStart);
        wrap.classList.toggle("can-right", !atEnd);
        /* İpucu bandı: en az bir kez kaydırıldıysa gizle */
        if (!atStart || tbl._scrolled) {
          tbl._scrolled = true;
          bar.classList.add("hidden");
        }
      }
      tbl.addEventListener("scroll", update, { passive: true });

      /* Gözlem: yalnızca gerçekten taşıyorsa göster */
      function checkOverflow() {
        if (!canScrollH(tbl)) {
          bar.classList.add("hidden");
          wrap.classList.remove("can-right");
        } else {
          wrap.classList.add("can-right");
          bar.classList.remove("hidden");
        }
        update();
      }

      /* ResizeObserver ile ekran boyutu değişince tekrar kontrol */
      if (window.ResizeObserver) {
        new ResizeObserver(checkOverflow).observe(tbl);
      }
      /* İlk kontrol biraz gecikmeli (fontlar yüklendikten sonra) */
      setTimeout(checkOverflow, 300);
    });
  }

  /* ── NAV TABS ── */
  function initNavHint() {
    var navTabs = document.querySelector(".nav-tabs");
    if (!navTabs) return;

    /* Sarmalayıcı */
    var wrap = document.createElement("div");
    wrap.className = "nav-tabs-wrap";
    navTabs.parentNode.insertBefore(wrap, navTabs);
    wrap.appendChild(navTabs);

    /* İpucu şeridi */
    var hint = document.createElement("div");
    hint.className = "nav-scroll-hint";
    hint.innerHTML =
      '<span class="sh-dot"></span>' +
      '<span>men&#252;y&#252; kayd&#305;r</span>' +
      '<span style="font-size:12px;margin-left:2px;">&#8594;</span>';
    wrap.parentNode.insertBefore(hint, wrap.nextSibling);

    function updateNav() {
      var atEnd = navTabs.scrollLeft >= navTabs.scrollWidth - navTabs.clientWidth - 2;
      wrap.classList.toggle("at-end", atEnd);
      if (navTabs.scrollLeft > 4) {
        hint.classList.remove("visible");
      }
    }
    navTabs.addEventListener("scroll", updateNav, { passive: true });

    function checkNav() {
      if (canScrollH(navTabs)) {
        hint.classList.add("visible");
      } else {
        hint.classList.remove("visible");
      }
      updateNav();
    }

    if (window.ResizeObserver) {
      new ResizeObserver(checkNav).observe(navTabs);
    }
    setTimeout(checkNav, 400);
  }

  /* ── Başlat ── */
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", function () {
      initTableHints();
      initNavHint();
    });
  } else {
    initTableHints();
    initNavHint();
  }
})();
</script>
<!-- ══ SİTE ALT BİLGİ (FOOTER) ══ -->
<style>
.site-footer {
  position: relative;
  z-index: 10;
  border-top: 1px solid rgba(29, 61, 107, 0.15);
