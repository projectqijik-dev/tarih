</main>

<script>
// ══════════════════════ TABS ══════════════════════
function showTab(id, btn) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ══════════════════════ TERMS DATA ══════════════════════
const terms = [
  { name:"Yazısız Hukuk", tag:"TAR.9.2.3", def:"Gelenek, görenek ve dinî kurallara dayanan, yazıya geçirilmemiş hukuk sistemi. Yazının icadından önceki dönemlerde toplumlarda uygulandı." },
  { name:"Lex Talionis", tag:"TAR.9.2.3", def:"'Kısasa kısas' anlamına gelen Latince ilke. Hammurabi Kanunları'nın özüdür: uğranan zararın birebir karşılığıyla cezalandırma anlayışı." },
  { name:"Hammurabi Kanunları", tag:"TAR.9.2.3", def:"MÖ 1754'te Babil Kralı Hammurabi tarafından çıkarılan, 282 maddeden oluşan ilk kapsamlı yazılı kanun külliyatı. Kısas ilkesine dayalıdır." },
  { name:"Urkagina Reformları", tag:"TAR.9.2.3", def:"MÖ 2375'te Lagaş Kralı Urkagina'nın ilan ettiği tarihte bilinen ilk yazılı sosyal reformlar. Rahiplerin sömürüsüne son vermeye ve zayıfları korumaya yönelikti." },
  { name:"12 Levha Kanunları", tag:"TAR.9.2.3", def:"MÖ 5. yüzyılda Roma'da Patriciler ile Plepler arasındaki sınıf çatışmalarını gidermek için yazılan Roma'nın ilk yazılı kanunları. Modern Avrupa hukukunun temelini oluşturur." },
  { name:"Ziggurat", tag:"TAR.9.2.4", def:"Sümerlilerin tanrılarının yeryüzündeki evi olarak inşa ettiği basamaklı kule tapınaklar. En üst katı aynı zamanda gözlemevi (rasathane) işlevi gördü." },
  { name:"Lamassu", tag:"TAR.9.2.4", def:"Asur saraylarının kapılarını süsleyen, kanatlı boğa ya da aslan gövdeli, insan başlı koruyucu tanrı heykeli. Din-sanat bütünleşmesinin somut örneğidir." },
  { name:"Mumyacılık", tag:"TAR.9.2.4", def:"Mısırlıların ahiret inancından doğan, cesedin ilaçlanarak korunması sanatı. İnsan anatomisini öğrenmelerini ve tıp bilimini geliştirmelerini sağladı." },
  { name:"Hipokrat", tag:"TAR.9.2.4", def:"Antik Yunan'da yaşayan ve tıbbı mitolojiden bağımsızlaştıran hekim. 'Tıbbın babası' olarak anılır; hastalıkları doğal nedenlerle açıklamaya çalışan ilk isimdir." },
  { name:"Skolastik Düşünce", tag:"TAR.9.3.1", def:"Orta Çağ Avrupası'nda Kilise dogmalarını esas alan, sorgulama ve eleştiriye kapalı düşünce sistemi. Kavimler Göçü'nün ardından Kilise'nin güçlenmesiyle yaygınlaştı." },
  { name:"Konargöçer", tag:"TAR.9.2.5", def:"Mevsimlik yaylak-kışlak döngüsüne dayanan, planlı ve düzenli yer değiştirme yaşam biçimi. Rastgele göçebelikten farklıdır; Türklerin tarihsel yaşam tarzıdır." },
  { name:"Yurt", tag:"TAR.9.2.5", def:"Türklerin konargöçer yaşamına uygun olarak geliştirdiği, keçeden yapılan, kolayca sökülüp taşınabilen çadır tipi konut. Pratik mimarinin simgesidir." },
  { name:"Ordu-Millet", tag:"TAR.9.2.5", def:"Türklerde toplumun tamamının asker sayıldığı anlayış. Eli silah tutan her kadın ve erkek asker kabul edildi; sivil-asker ayrımı yoktu." },
  { name:"Onlu Sistem", tag:"TAR.9.2.5", def:"Mete Han'ın Asya Hun Devleti'nde kurduğu, orduyu onbaşı-yüzbaşı-binbaşı-tümenbey kademelerine ayıran askeri örgütlenme sistemi. Modern ordu hiyerarşisinin ilk örneği." },
  { name:"Turan Taktiği", tag:"TAR.9.2.5", def:"'Hilal' veya 'Kurt Kapanı' olarak da bilinen Türk askeri stratejisi. Sahte geri çekilmeyle düşmanı yayarak kuşatma ve imha etme taktiği." },
  { name:"Hayvan Üslubu", tag:"TAR.9.2.5", def:"Türk sanatında at koşum takımları, kemer tokaları gibi taşınabilir eşyalar üzerinde işlenen kurt, kaplan, geyik mücadele sahneleri. Bozkır kültürünün görsel ifadesidir." },
  { name:"Kavimler Göçü", tag:"TAR.9.3.1", def:"MS 375 dolaylarında Hunların batıya göç etmesiyle tetiklenen ve Germen kavimlerini Roma sınırlarına iten büyük nüfus hareketi. Antik Çağ'ın sonu Orta Çağ'ın başlangıcı sayılır." },
  { name:"Feodalizm", tag:"TAR.9.3.1", def:"Orta Çağ Avrupası'nda Roma'nın çöküşünden sonra ortaya çıkan; toprak, himaye ve askerlik hizmetine dayalı yerel derebeylik yönetim sistemi." },
  { name:"Batı Roma'nın Çöküşü", tag:"TAR.9.3.1", def:"MS 476'da Germen komutan Odoacer'in son imparatoru tahttan indirmesiyle gerçekleşen olay. Antik Çağ'ın resmi bitiş noktası olarak kabul edilir." },
  { name:"Töre", tag:"TAR.9.2.5", def:"Türklerde yazılı olmayan ancak bağlayıcı olan gelenek ve adet hukuku. Suçlara tazminat veya ölüm cezası öngördü; bozkır koşullarına özgü yaptırım sistemidir." },
];

// ══════════════════════ FLASHCARDS DATA ══════════════════════
const flashcards = [
  { tag:"TAR.9.2.3", front:"Tarihte bilinen ilk yazılı kanunları kim, hangi amaçla ilan etti?", fsub:"", back:"MÖ 2375 — Lagaş Kralı Urkagina\nRahiplerin sömürüsünü engellemek ve zayıfları korumak için.", bsub:"Sümerlilerin hukuki öncülüğünün başlangıcıdır." },
  { tag:"TAR.9.2.3", front:"Hammurabi Kanunları'nın temel ilkesi nedir? Ne anlama gelir?", fsub:"", back:"Lex Talionis — Kısasa Kısas\nUğranan zararın birebir karşılığıyla cezalandırma.", bsub:"Toplumsal sınıfa göre ceza değişiyordu." },
  { tag:"TAR.9.2.3", front:"Hitit kanunlarını Mezopotamya'dan ayıran en belirgin özellik nedir?", fsub:"", back:"İdamın yerini maddi tazminat aldı.\nKasıt-kaza ayrımı yapıldı; kadınlara boşanma hakkı tanındı.", bsub:"Çağının en insancıl hukuk sistemi kabul edilir." },
  { tag:"TAR.9.2.3", front:"12 Levha Kanunları neden çıkarıldı ve önemi nedir?", fsub:"Roma Hukuku", back:"Patriciler ile Plepler arasındaki sınıf çatışmalarını gidermek için.\nModern Avrupa hukukunun temelini oluşturur.", bsub:"MÖ 5. yüzyıl, Roma" },
  { tag:"TAR.9.2.4", front:"Sümer Zigguratları hem dini hem bilimsel bir işlev üstlendi. Bu hangi bilimi doğurdu?", fsub:"", back:"Ziggurat'ın üst katı gözlemeviydi.\nRahipler gökyüzü gözlemleriyle ASTRONOMİ ve Ay Yılı TAKVİMİ'ni geliştirdi.", bsub:"Din → İhtiyaç → Bilim zincirinin en güzel örneği" },
  { tag:"TAR.9.2.4", front:"Mısır'da mumyacılık geleneği hangi iki bilim dalının gelişmesini sağladı?", fsub:"İnanç-bilim ilişkisi", back:"1. Tıp — iç organlar öğrenildi\n2. Eczacılık — ilaç ve balsam kullanımı", bsub:"Ahiret inancı anatomi bilgisini mümkün kıldı." },
  { tag:"TAR.9.2.4", front:"Antik Yunan'da inançtan bilime geçişin simgesi sayılan hekim kimdir?", fsub:"", back:"Hipokrat — 'Tıbbın Babası'\nHastalıkları tanrısal ceza değil, doğal nedenlerle açıkladı.", bsub:"İyonya ekolünün tıp alanındaki karşılığıdır." },
  { tag:"TAR.9.2.5", front:"'Konargöçer' ile 'göçebe' arasındaki fark nedir?", fsub:"Önemli kavram!", back:"Göçebe: rastgele yer değiştirir.\nKonargöçer: mevsimlik yaylak-kışlak döngüsü yapar. Planlıdır.", bsub:"Türkler konargöçerdir, sıradan göçebe değil." },
  { tag:"TAR.9.2.5", front:"Mete Han'ın kurduğu Onlu Sistem nasıl çalışıyordu?", fsub:"Asya Hun Devleti", back:"Ordu onbaşı → yüzbaşı → binbaşı → tümenbey kademelerine ayrıldı.\nModern ordu hiyerarşisinin ilk örneği.", bsub:"Bu disiplin Roma ve Çin'i yendi." },
  { tag:"TAR.9.2.5", front:"Türk sanatında 'Hayvan Üslubu' neden gelişti ve nasıl uygulandı?", fsub:"", back:"Doğayla iç içe bozkır yaşamı → kurt, kaplan, geyik sahneleri\nKemer tokası, at koşumu, kılıç kabzası gibi taşınabilir eşyalara işlendi.", bsub:"Konargöçer yaşam sanat anlayışını biçimlendirdi." },
  { tag:"TAR.9.3.1", front:"Kavimler Göçü'nün üç temel nedeni nedir?", fsub:"MS 375", back:"1. Orta Asya'da kuraklık ve otlak yetersizliği\n2. Çin baskısı\n3. Nüfus artışı", bsub:"Balamir liderliğindeki Hunlar batıya ilerleyince domino etkisi başladı." },
  { tag:"TAR.9.3.1", front:"Kavimler Göçü'nün Avrupa'daki iki büyük siyasi sonucu nedir?", fsub:"", back:"1. Roma 395'te ikiye ayrıldı.\n2. Batı Roma 476'da yıkıldı → Feodalizm doğdu.", bsub:"Antik Çağ bitti, Orta Çağ başladı." },
  { tag:"TAR.9.3.1", front:"Feodalizm nedir ve neden ortaya çıktı?", fsub:"Orta Çağ Avrupası", back:"Roma'nın çöküşüyle oluşan güvenlik boşluğu doldurmak için.\nToprak ve himayeye dayalı yerel derebeylik sistemi.", bsub:"Merkezi devletin yerini yerel dükler-kontlar aldı." },
  { tag:"TAR.9.3.1", front:"Türk-Hun kültürünün Avrupalılara aktardığı üç teknoloji nedir?", fsub:"Kültürel etkileşim", back:"1. Üzengi (atlı savaşı dönüştürdü)\n2. Pantolon ve ceket giyimi\n3. Atlı süvari taktikleri", bsub:"Kavimler Göçü salt yıkım değil, kültür transferiydi." },
];

// ══════════════════════ QUIZ DATA ══════════════════════
const quizData = [
  {
    q:"Hammurabi Kanunları'nı Urkagina'nın yasalarından ayıran en temel özellik hangisidir?",
    opts:["Urkagina'nın daha sert cezalar öngörmesi","Hammurabi'nin 'kısasa kısas' ilkesini benimsemesi ve toplumsal sınıfa göre ceza değiştirmesi","Hammurabi'nin zayıfları ve yoksulları korumaya öncelik vermesi","Urkagina'nın kanunlarını taş levhaya yazdırması"],
    ans:1,
    fb:"Hammurabi Kanunları lex talionis (kısasa kısas) ilkesine dayalıdır ve suçlunun toplumsal statüsüne göre ceza değişir. Urkagina ise zayıfları koruma odaklıydı."
  },
  {
    q:"Hitit hukuku Mezopotamya hukukuna göre neden 'daha insancıl' olarak değerlendirilir?",
    opts:["Hititlerin daha küçük bir devlet olması","İdamın ve işkencenin yerini maddi tazminat alması; kasıt-kaza ayrımı yapılması","Hititlerde yazılı kanun bulunmaması","Hititlerde suçlulara sürgün cezası verilmesi"],
    ans:1,
    fb:"Hitit kanunları ağır bedeni cezalar yerine orantılı tazminat sistemini benimsedi ve kasıt-kaza farkını hukuken ayırdı. Bu Mezopotamya geleneğiyle keskin bir tezat oluşturur."
  },
  {
