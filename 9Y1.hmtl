    opts:["Zigguratlar kütüphane olarak kullanıldı","Rahipler tanrıların iradesini okumak için gözlemevi olarak kullandı ve astronomi ile takvim gelişti","Zigguratlar tıp okulu işlevi gördü","Zigguratlar mimari eğitim mekânıydı"],
    ans:1,
    fb:"Zigguratların en üst katı rasathane (gözlemevi) olarak kullanıldı. Din güdümlü gözlemler astronominin, ardından Ay takviminin doğmasını sağladı."
  },
  {
    q:"Mısır'da mumyacılık sanatının bilimsel önemi nedir?",
    opts:["Mimari tekniğin ilerlemesini sağladı","İnsan anatomisinin öğrenilmesine zemin hazırlayarak tıp ve eczacılığı geliştirdi","Matematik biliminin temellerini attı","Takvim hesaplamalarına olanak tanıdı"],
    ans:1,
    fb:"Cesedin iç organlarının çıkarılıp ilaçlanması süreci insan vücudunun çok iyi tanınmasını sağladı. Bu bilgi birikimi tıp ve eczacılık alanında çağının çok ötesine geçilmesine yol açtı."
  },
  {
    q:"Antik Yunan'da Hipokrat'ın tıp anlayışının fark yaratan boyutu nedir?",
    opts:["Tanrıları memnun etmek için dualar yazması","Hastalıkları tanrısal ceza değil, doğal nedenler sonucu olarak açıklaması","Cerrahi teknikleri geliştirmesi","Olimpiyat oyunlarını düzenlemesi"],
    ans:1,
    fb:"Hipokrat, hastalıkların mitolojik tanrılarla değil doğa ve yaşam koşullarıyla ilişkili olduğunu savundu. Bu yaklaşım tıbbı inançtan bağımsız bir bilim dalına dönüştürdü."
  },
  {
    q:"'Konargöçer' yaşam biçiminin sıradan 'göçebelikten' farkı nedir?",
    opts:["Konargöçerler sabit şehirlerde yaşardı","Konargöçerlik mevsimlik yaylak-kışlak döngüsüne dayalı planlı yer değiştirmedir; göçebelik rastgeledir","Konargöçerler yalnızca tarımla geçimini sağlardı","Göçebeler çadır kullanmazdı"],
    ans:1,
    fb:"Konargöçerlik sistematik ve planlı bir harekettir: yazın serin yaylalara, kışın ılık kışlaklara göç edilir. Bu döngü ekonomik ve ekolojik bir akıldır, rastgele hareket değil."
  },
  {
    q:"Türklerde 'ordu-millet' anlayışının konargöçer yaşamla ilişkisi nasıl kurulabilir?",
    opts:["Bozkırda sürekli savaş olduğu için tüm nüfus silahlanmak zorundaydı","Konargöçer yaşamın zorlu koşulları her bireyi dayanıklı ve savaşa hazır kılarken kalıcı şehir savunması gerekmediğinden ordu ayrımı yoktu","Mete Han böyle bir kanun çıkardı","Türkler başka devletlerin ordularını devraldı"],
    ans:1,
    fb:"Bozkır yaşamı hem fiziksel dayanıklılığı hem de sürekli hareket yeteneğini zorunlu kıldı. Kalıcı duvarlarla savunulacak şehirler olmadığından her birey asker olarak yetişti."
  },
  {
    q:"Kavimler Göçü'nün başlangıcını tetikleyen doğrudan etken nedir?",
    opts:["Roma İmparatorluğu'nun Hunlara savaş açması","Orta Asya kuraklığı ve Çin baskısıyla batıya ilerleyen Hunların Germen kavimlerini Roma sınırlarına doğru itmesi","Vizigotların Hunlara savaş açması","İklim değişikliği nedeniyle Hunların Avrupa'yı tercih etmesi"],
    ans:1,
    fb:"Balamir önderliğindeki Hunlar kuraklık ve Çin baskısıyla batıya ilerledi. Karadeniz kuzeyindeki Germen kavimlerini önlerine katarak Roma sınırlarına doğru itmesiyle domino etkisi başladı."
  },
  {
    q:"Batı Roma İmparatorluğu hangi tarihte, kim tarafından yıkıldı?",
    opts:["MS 395 — Theodosius tarafından","MS 476 — Germen komutan Odoacer tarafından","MS 410 — Vizigot Kral Alaric tarafından","MS 455 — Vandal Kral Geiserik tarafından"],
    ans:1,
    fb:"MS 476'da Germen asıllı Odoacer, son Batı Roma İmparatoru'nu tahttan indirdi. Bu tarih Antik Çağ'ın bitişi ve Orta Çağ'ın başlangıcı olarak kabul edilir."
  },
  {
    q:"Kavimler Göçü sonrasında Avrupa'da Feodalite'nin (Derebeylik) ortaya çıkmasının temel nedeni nedir?",
    opts:["Kilisenin siyasi öneri sunması","Roma'nın çöküşüyle oluşan güvenlik ve otorite boşluğunu yerel derebeylerin doldurması","Türklerin Avrupa'yı yönetmesi","Ticaretin gelişmesi"],
    ans:1,
    fb:"Merkezi Roma yönetimi çözülünce halk güvenlik için yerel beylere (kontlar, dükler) sığındı. Toprak ve askerlik hizmetine dayalı bu himaye ilişkisi Feodalizm'i doğurdu."
  },
  {
    q:"Kavimler Göçü'nün kültürel etkileşim boyutuna göre, Türk-Hun kültüründen Avrupalılara geçen en önemli askeri yenilik hangisidir?",
    opts:["Demir kılıç üretimi","Üzengi ve atlı süvari taktikleri","Kale inşaat teknikleri","Çelik zırh yapımı"],
    ans:1,
    fb:"Hunlardan Avrupalılara geçen üzengi, atlı muharebenin biçimini kökten değiştirdi. Atlı süvari taktikleri Orta Çağ Avrupa savaş sanatının temelini oluşturdu."
  },
  {
    q:"12 Levha Kanunları ile Hammurabi Kanunları arasındaki en temel felsefi fark nedir?",
    opts:["Hammurabi kanunları daha eskidir","12 Levha yurttaş haklarını güvence altına alırken Hammurabi sınıfsal eşitsizliği pekiştiren bir hiyerarşik ceza düzeni kurdu","12 Levha daha sert cezalar öngördü","Hammurabi kanunları Avrupa'da da uygulandı"],
    ans:1,
    fb:"Hammurabi soylu-halk-köle ayrımına göre farklı ceza uygulayarak sınıf hiyerarşisini meşrulaştırdı. 12 Levha ise tüm yurttaşlara yazılı güvenceler sunarak eşit hukuki zemin oluşturdu."
  },
];

// ══════════════════════ TERMS RENDER ══════════════════════
const tg = document.getElementById('termsGrid');
const td = document.getElementById('termDef');
let openTerm = -1;

terms.forEach((t, i) => {
  const chip = document.createElement('div');
  chip.className = 'term-chip';
  chip.innerHTML = t.name;
  chip.onclick = () => {
    document.querySelectorAll('.term-chip').forEach(c => c.classList.remove('open'));
    if (openTerm === i) { td.classList.remove('show'); openTerm = -1; return; }
    chip.classList.add('open');
    document.getElementById('termTitle').textContent = t.name;
    document.getElementById('termText').innerHTML = `<span style="font-family:'IBM Plex Mono',monospace;font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--red);display:inline-block;margin-bottom:8px;">${t.tag}</span><br>${t.def}`;
    td.classList.add('show');
    openTerm = i;
  };
  tg.appendChild(chip);
});

// ══════════════════════ FLASHCARDS ══════════════════════
let fcIdx = 0;
function updateFC() {
  const c = flashcards[fcIdx];
  document.getElementById('fcFront').textContent = c.front;
  document.getElementById('fcFrontSub').textContent = c.fsub || '';
  document.getElementById('fcBack').textContent = c.back;
  document.getElementById('fcBackSub').textContent = c.bsub || '';
  document.getElementById('fcIndex').textContent = 'Kart ' + (fcIdx + 1);
  document.getElementById('fcTotal').textContent = flashcards.length + ' kart';
  document.getElementById('fcBar').style.width = ((fcIdx + 1) / flashcards.length * 100) + '%';
  document.getElementById('fcTag').textContent = c.tag;
  document.getElementById('fcTagBack').textContent = c.tag;
  document.getElementById('flashcard').classList.remove('flipped');
}
function flipCard() { document.getElementById('flashcard').classList.toggle('flipped'); }
function nextCard() { fcIdx = (fcIdx + 1) % flashcards.length; updateFC(); }
function prevCard() { fcIdx = (fcIdx - 1 + flashcards.length) % flashcards.length; updateFC(); }
updateFC();

// ══════════════════════ QUIZ ══════════════════════
let qIdx = 0, qScore = 0, answered = false;

function renderQuiz() {
  const qa = document.getElementById('quizArea');
  if (qIdx >= quizData.length) {
    const pct = Math.round(qScore / quizData.length * 100);
    let msg = '';
    if (pct >= 80) msg = 'Harika! Tüm kazanımlara hâkimiyetin çok iyi. 🏆';
    else if (pct >= 60) msg = 'İyi iş çıkardın! Eksik kaldığın kazanımları tekrar incele. 📚';
    else msg = 'Tekrar yapalım. Ders notlarına bir kez daha bak ve yeniden dene. 💪';
    qa.innerHTML = `<div class="score-display">
      <div class="score-big">${pct}%</div>
      <div class="score-label">${qScore} / ${quizData.length} Doğru</div>
      <div class="score-msg">${msg}</div>
      <button class="fc-btn primary" onclick="qIdx=0;qScore=0;answered=false;renderQuiz()">↺ Tekrar Başla</button>
    </div>`;
    return;
  }
  const d = quizData[qIdx];
  qa.innerHTML = `<div class="quiz-q">
    <div class="quiz-q-num">Soru ${qIdx + 1} / ${quizData.length}</div>
    <div class="quiz-q-text">${d.q}</div>
    <div class="quiz-options">
      ${d.opts.map((o, i) => `<div class="quiz-opt" id="opt${i}" onclick="selectOpt(${i})">${String.fromCharCode(65 + i)}) ${o}</div>`).join('')}
    </div>
    <div class="quiz-feedback" id="qFb"></div>
    <div class="quiz-nav">
      <div class="quiz-score-badge">Puan: ${qScore} / ${qIdx}</div>
      <button class="fc-btn primary" id="nextBtn" onclick="nextQ()" style="display:none">Sonraki →</button>
    </div>
  </div>`;
  answered = false;
}

function selectOpt(i) {
  if (answered) return;
  answered = true;
  const d = quizData[qIdx];
  document.querySelectorAll('.quiz-opt').forEach(o => o.classList.add('disabled'));
  const fb = document.getElementById('qFb');
  if (i === d.ans) {
    document.getElementById('opt' + i).classList.add('correct');
    fb.textContent = '✓ Doğru! ' + d.fb;
    fb.className = 'quiz-feedback show ok';
    qScore++;
  } else {
    document.getElementById('opt' + i).classList.add('wrong');
    document.getElementById('opt' + d.ans).classList.add('correct');
    fb.textContent = '✗ Yanlış. Doğru cevap: ' + d.opts[d.ans] + '. ' + d.fb;
    fb.className = 'quiz-feedback show fail';
  }
  document.getElementById('nextBtn').style.display = 'inline-block';
}

function nextQ() { qIdx++; renderQuiz(); }
renderQuiz();
</script>

